{"head":73,"savepointDataFileId":"690243697643","savepointListObject":{},"lastEditTimestamp":1594519319761,"diffChangeset":"Z:1>5x*4*5*6+5w|1+1$No patterns. Probably only good if I vacuum anneal, electropolish, or do the argon ion polishing. Really, would be better to use in the induction furnace, get a lot of grain growth, then polish and vacuum anneal.\n","invalidDiffChangeset":false,"authorList":{"3351161222":{"authorName":"Sterling Baird","authorCustomAvatarUrl":"/users/3351161222/avatar"}},"diffAuthorList":{"3351161222":true},"shouldCreateSavepointBeforeApplyingNextRevision":false,"firstKeyRevision":5,"atext":{"text":"No patterns. Probably only good if I vacuum anneal, electropolish, or do the argon ion polishing. Really, would be better to use in the induction furnace, get a lot of grain growth, then polish and vacuum anneal.\n\n","attribs":"*4*5*6+5w|2+2","opCount":2,"appliedAttribsCount":3,"maxAttribsOnSingleOp":3},"pool":{"numToAttrib":{"0":["author","a.4fz9s4pIrvcRKF5l"],"1":["align","left"],"2":["insertorder","first"],"3":["lmkr","1"],"4":["author","3351161222"],"5":["font-color-000000","true"],"6":["font-size-medium","true"],"7":["removed","true"]},"nextNum":8},"chatHead":-1,"publicStatus":false,"passwordHash":null,"savedRevisions":[]}